# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Analytics
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_YANDEX_METRICA_ID=XXXXXXXX

# Search Engine Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# Rate limiting (Upstash Redis — https://upstash.com/docs/redis/overall/rest)
# Optional but strongly recommended on Vercel serverless; without these, the
# /api/booking route falls back to a per-instance in-memory limiter that is
# ineffective across cold starts. Create a Redis DB in Upstash and copy the
# REST URL + REST Token values.
UPSTASH_REDIS_REST_URL=https://XXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=AYYY
